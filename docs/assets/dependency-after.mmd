flowchart TB
  subgraph app["App / Orchestration"]
    MAIN[main.py]
    IR[intent_router.py]
    DCS[dynamic_context_scheduler.py]
    PB[prompt_builder.py]
  end

  subgraph adapters["adapters.* — public I/O surface"]
    direction TB
